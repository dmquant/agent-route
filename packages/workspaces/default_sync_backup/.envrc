# direnv configuration for AI Stock Research Institute
# Requires: direnv (https://direnv.net)
# Usage: `direnv allow` to activate

# Prefer uv-managed virtualenv; fall back to local .venv
if has uv; then
    # uv sync creates .venv automatically; just activate it
    if [ -d .venv ]; then
        source .venv/bin/activate
    fi
else
    if [ -d .venv ]; then
        source .venv/bin/activate
    fi
fi

# Load .env file into shell environment
dotenv_if_exists .env
