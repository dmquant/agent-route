# ==========================================
# AI Agents Route Service - Configuration
# ==========================================

# --------------------------
# Services & Agents Dispatch
# --------------------------
# Set these to 'true' or 'false' to enable/disable specific CLI routing hooks
# When enabled, the bridge server will spawn necessary background listeners 
# and accept WebSockets.

ENABLE_CLAUDE_REMOTE_CONTROL=true
ENABLE_GEMINI_CLI=true
ENABLE_CODEX_SERVER=false

# --------------------------
# Port Configurations
# --------------------------
FRONTEND_PORT=5173
BACKEND_PORT=8787
